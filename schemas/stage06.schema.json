      "type": "object",
      "required": [
        "stage",
        "status",
        "record_counts",
        "primary_fact_source"
      ],
      "properties": {
        "stage": {
          "const": 6
        },
        "stage_name": {
          "type": "string"
        },
        "status": {
          "const": "final_approved"
        },
        "approval_date": {
          "type": "string"
        },
        "primary_fact_source": {
          "type": "string"
        },
        "record_counts": {
          "type": "object",
          "required": [
            "parties",
            "increase_events",
            "subscriptions",
            "transfer_events",
            "transfer_lots",
            "snapshots",
            "snapshot_holdings",
            "calculations",
            "evidence_reviews",
            "acceptance_checks",
            "audit_log"
          ],
          "properties": {
            "parties": {
              "type": "integer",
              "minimum": 0
            },
            "increase_events": {
              "type": "integer",
              "minimum": 0
            },
            "subscriptions": {
              "type": "integer",
              "minimum": 0
            },
            "transfer_events": {
              "type": "integer",
              "minimum": 0
            },
            "transfer_lots": {
              "type": "integer",
              "minimum": 0
            },
            "snapshots": {
              "type": "integer",
              "minimum": 0
            },
            "snapshot_holdings": {
              "type": "integer",
              "minimum": 0
            },
            "calculations": {
              "type": "integer",
              "minimum": 0
            },
            "evidence_reviews": {
              "type": "integer",
              "minimum": 0
            },
            "acceptance_checks": {
              "type": "integer",
              "minimum": 0
            },
            "audit_log": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "tables": {
      "type": "object",
      "required": [
        "parties",
        "increase_events",
        "subscriptions",
        "transfer_events",
        "transfer_lots",
        "snapshots",
        "snapshot_holdings",
        "calculations",
        "evidence_reviews",
